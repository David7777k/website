# Database
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Google OAuth (для входа через Google)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Maps API (для карт и направлений)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Spotify API (для джукбокса)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

# Payment Configuration (опционально)
LIQPAY_PUBLIC_KEY="your-liqpay-public-key"
LIQPAY_PRIVATE_KEY="your-liqpay-private-key"

# Application Settings
APP_NAME="PANDA Lounge"
APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"